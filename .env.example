# Production Configuration
# Zkopírujte do .env.production a upravte dle potřeby

PORT=3000
NODE_ENV=production

# LibreOffice path (Windows)
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program

# LibreOffice path (Linux)
# LIBREOFFICE_PATH=/usr/bin

# LibreOffice path (macOS)
# LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS

# Max file size in MB
MAX_FILE_SIZE_MB=50

# Callback timeout in ms for sending created PDFs to external REST API
CALLBACK_TIMEOUT_MS=15000

# Optional Bearer token required by /api/template/extract-variables
# EXTRACTION_AUTH_TOKEN=change-me

# Optional Basic Auth for all public API endpoints (recommended for quick testing)
BASIC_AUTH_USER=testuser
BASIC_AUTH_PASS=test1234

# Logging
LOG_LEVEL=info
